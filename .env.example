# Inclusify Environment Variables
# Copy to .env and customize for your environment

# ============================================
# Database Configuration
# ============================================
# Local dev defaults work with docker compose
PGHOST=postgres
PGPORT=5432
PGDATABASE=inclusify
PGUSER=postgres
PGPASSWORD=devpassword
# Set to "require" for production with SSL
PGSSL=

# ============================================
# Frontend Configuration
# ============================================
# API URL for frontend to call backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Build Configuration
# ============================================
# development or runtime (for production)
BUILD_TARGET=development

# Version info (populated by CI/CD)
BUILD_TIME=
GIT_COMMIT=
