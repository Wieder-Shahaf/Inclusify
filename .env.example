# Inclusify Environment Variables
# Copy to .env and customize for your environment
#
# The real .env with secrets is shared via team OneDrive.
# For local dev, copy this file and fill in the secrets manually.

# ============================================
# Database Configuration
# ============================================
# Docker Compose: PGHOST=postgres | Native setup: PGHOST=localhost
PGHOST=postgres
PGPORT=5432
PGDATABASE=inclusify
PGUSER=postgres
PGPASSWORD=devpassword

# Set to "require" for production (Azure PostgreSQL). Leave empty for local dev.
PGSSL=

# Azure PostgreSQL admin password. Used by infra/scripts/azure-deploy.sh. Not needed for local dev.
PG_PASSWORD=

# ============================================
# Authentication
# ============================================
# JWT signing secret. Required. Use a long random string in production.
JWT_SECRET=dev-secret-change-in-production

# Google OAuth credentials. Required for Google login. Get from Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# Frontend Configuration
# ============================================
# URL the backend uses for OAuth redirects and CORS. Default works for local dev.
FRONTEND_URL=http://localhost:3000

# API URL for frontend to call backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Demo mode toggle. Set to "true" to use mock data without a running backend.
NEXT_PUBLIC_USE_DEMO_MODE=false

# ============================================
# Backend Configuration
# ============================================
# CORS allowed origins (comma-separated). Falls back to localhost:3000 if empty.
ALLOWED_ORIGINS=http://localhost:3000

# vLLM inference endpoint. Points to Azure GPU VM.
VLLM_URL=http://52.224.246.238:8001

# Redis URL for refresh token storage. Optional — auth works without it (no refresh tokens).
REDIS_URL=redis://localhost:6379

# ============================================
# Build Configuration
# ============================================
# "development" for local dev, "runtime" for production Docker builds
BUILD_TARGET=development

# Version info (populated by CI/CD, leave empty for local dev)
BUILD_TIME=
GIT_COMMIT=
